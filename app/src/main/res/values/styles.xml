<resources>
    <style name="AppTheme.Light" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/onSurface</item>
        <item name="colorOnPrimary">@color/onPrimary</item>
        <item name="android:textColorPrimary">@color/textColorPrimary</item>
        <item name="backgroundColor">@color/backgroundListItem</item>
        <item name="android:actionMenuTextColor">@color/textColorPrimary</item>
        <item name="materialButtonStyle">@style/Widget.TheFamilyApp.Button</item>
        <item name="materialCardViewStyle">@style/Widget.TheFamilyApp.Card</item>
        <item name="textInputStyle">@style/Widget.TheFamilyApp.TextInputLayout</item>
        <item name="bottomNavigationStyle">@style/Widget.TheFamilyApp.BottomNavigation</item>
        <item name="navigationViewStyle">@style/Widget.TheFamilyApp.NavigationView</item>
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.TheFamilyApp.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.TheFamilyApp.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.TheFamilyApp.Large</item>
    </style>

    <style name="ShapeAppearance.TheFamilyApp.Small" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">10dp</item>
    </style>

    <style name="ShapeAppearance.TheFamilyApp.Medium" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="ShapeAppearance.TheFamilyApp.Large" parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

    <style name="Widget.TheFamilyApp.Button" parent="Widget.MaterialComponents.Button">
        <item name="shapeAppearance">@style/ShapeAppearance.TheFamilyApp.Medium</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:textStyle">bold</item>
        <item name="backgroundTint">@color/colorPrimary</item>
        <item name="android:textColor">@color/onPrimary</item>
    </style>

    <style name="Widget.TheFamilyApp.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/backgroundListItem</item>
        <item name="strokeColor">@color/colorAccent</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.TheFamilyApp.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/surface</item>
        <item name="boxStrokeColor">@color/colorPrimary</item>
        <item name="boxStrokeWidth">2dp</item>
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
        <item name="hintTextColor">@color/Grey</item>
    </style>

    <style name="Widget.TheFamilyApp.BottomNavigation" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="itemIconTint">@drawable/selector</item>
        <item name="itemTextColor">@drawable/selector</item>
        <item name="itemRippleColor">@color/colorAccent</item>
        <item name="elevation">10dp</item>
        <item name="android:background">@color/surface</item>
    </style>

    <style name="Widget.TheFamilyApp.NavigationView" parent="Widget.MaterialComponents.NavigationView">
        <item name="itemIconTint">@color/textColorPrimary</item>
        <item name="itemTextColor">@color/textColorPrimary</item>
        <item name="android:background">@color/backgroundColor</item>
    </style>

    <style name="Widget.TheFamilyApp.Toolbar" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:background">@color/surface</item>
        <item name="titleTextColor">@color/textColorPrimary</item>
        <item name="subtitleTextColor">@color/Grey</item>
    </style>

    <style name="MyDialogStyle" parent="Theme.MaterialComponents.DayNight.Dialog.Alert">
        <item name="android:background">@color/backgroundColorAlert</item>
        <item name="android:textColorPrimary">@color/textColorAlert</item>
        <item name="android:buttonBarNegativeButtonStyle">@style/NegativeButtonStyle</item>
        <item name="android:buttonBarPositiveButtonStyle">@style/PositiveButtonStyle</item>
    </style>

    <style name="NegativeButtonStyle" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColorPrimary">@color/buttonColorAlert</item>
    </style>

    <style name="PositiveButtonStyle" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColorPrimary">@color/buttonColorAlert</item>
    </style>

    <style name="DialogTheme" parent="Theme.MaterialComponents.DayNight.Dialog">
        <item name="colorAccent">@color/TimePickerAccent</item>
        <item name="colorControlNormal">@color/TimePickerColorControl</item>
        <item name="android:background">@color/backgroundColorTimePicker</item>
        <item name="android:buttonBarNegativeButtonStyle">@style/NegativeButtonStyle</item>
        <item name="android:buttonBarPositiveButtonStyle">@style/PositiveButtonStyle</item>
    </style>

    <style name="my_dialog_theme" parent="ThemeOverlay.MaterialComponents.Dialog">
        <item name="colorAccent">@color/headerBackground</item>
        <item name="android:windowBackground">@color/calenderBackground</item>
        <item name="android:colorControlActivated">@color/selectedDay</item>
        <item name="android:textColorPrimary">@color/daysOfTheMonth</item>
        <item name="android:textColorSecondary">@color/daysOfTheWeek</item>
        <item name="android:buttonBarPositiveButtonStyle">@style/DatePickerButtonStyle</item>
        <item name="android:buttonBarNegativeButtonStyle">@style/DatePickerButtonStyle</item>
    </style>

    <style name="DatePickerButtonStyle" parent="Base.Widget.AppCompat.Button.Borderless">
        <item name="android:textColor">@color/buttonColor</item>
        <item name="android:backgroundTint">@color/backgroundTint</item>
    </style>

    <style name="datepicker">
        <item name="colorControlNormal">@color/colorPrimary</item>
    </style>

    <style name="CalenderViewDateCustomText" parent="android:TextAppearance.DeviceDefault.Small">
        <item name="android:textColor">@color/textColorPrimary</item>
        <item name="android:weekNumberColor">@color/textColorPrimary</item>
    </style>

    <style name="spinner">
        <item name="borderWidth">1dp</item>
        <item name="color">@color/colorPrimary</item>
    </style>
</resources>
