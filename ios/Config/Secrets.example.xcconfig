// Copy this file to Secrets.xcconfig (gitignored) and fill in the real values —
// the same SUPABASE_URL / SUPABASE_ANON_KEY as android/local.properties.
//
// NOTE the $() in the URL: xcconfig treats // as a comment, so the empty
// variable expansion escapes the second slash.
SUPABASE_URL = https:/$()/your-project.supabase.co
SUPABASE_ANON_KEY = your-anon-key
